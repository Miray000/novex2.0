generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}

model Report {
  id        Int      @id @default(autoincrement())
  date      String
  product   String
  rows      Json
  createdAt DateTime @default(now())
}

model KeitaroReport {
  id        Int      @id @default(autoincrement())
  date      String
  campaign  String
  rows      Json
  group     String?
  createdAt DateTime @default(now())
}

 model UnityReport {
  id        Int      @id @default(autoincrement())
  date      String
  app_id    String
  app_name  String
  spend     Float
  createdAt DateTime @default(now())
}

model AppSpend {
  id        Int      @id @default(autoincrement())
  date      String
  app_name  String
  spend     Float
  createdAt DateTime @default(now())
}
