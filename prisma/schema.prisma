generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}

model Report {
  id        Int      @id @default(autoincrement())
  date      String
  product   String
  rows      Json
  createdAt DateTime @default(now())
}

model KeitaroReport {
  id        Int      @id @default(autoincrement())
  date      String
  campaign  String
  rows      Json
  createdAt DateTime @default(now())
}

 
